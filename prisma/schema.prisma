generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  OTHER
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum TransferStatus {
  DRAFT
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum AutomationTriggerType {
  MANUAL
  SCHEDULED
  EVENT
}

enum AutomationRunStatus {
  PENDING
  SUCCESS
  FAILED
}

model Product {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  sku          String        @unique
  name         String
  description  String?
  sellingPrice Int
  costPrice    Int
  taxRate      Float              @default(0)
  reorderLevel Int           @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  inventory    Inventory?
  saleItems    PosBillItem[]
  warehouseStocks WarehouseStock[]
  transferItems WarehouseTransferItem[]
}

model Customer {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  code        String    @unique
  name        String
  phone       String?
  email       String?
  address     String?
  creditLimit Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bills       PosBill[]
}

model Warehouse {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  code         String              @unique
  name         String
  location     String?
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  stocks       WarehouseStock[]
  transfersOut WarehouseTransfer[] @relation("WarehouseTransferFrom")
  transfersIn  WarehouseTransfer[] @relation("WarehouseTransferTo")
}

model WarehouseStock {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  warehouseId String    @db.ObjectId
  productId   String    @db.ObjectId
  quantity    Int       @default(0)
  updatedAt   DateTime  @updatedAt
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
}

model Inventory {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  productId   String          @unique @db.ObjectId
  onHandQty   Int             @default(0)
  reservedQty Int             @default(0)
  updatedAt   DateTime        @updatedAt
  product     Product         @relation(fields: [productId], references: [id])
  movements   StockMovement[]
}

model StockMovement {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  inventoryId String            @db.ObjectId
  type        StockMovementType
  quantity    Int
  note        String?
  reference   String?
  createdAt   DateTime          @default(now())
  inventory   Inventory         @relation(fields: [inventoryId], references: [id])
}

model PosBill {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  billNumber    Int
  customerName  String?
  customerId    String?      @db.ObjectId
  subtotal      Int
  taxAmount     Int
  totalAmount   Int
  paidAmount    Int
  changeAmount  Int          @default(0)
  paymentMethod PaymentMethod
  createdAt     DateTime     @default(now())
  items         PosBillItem[]
  invoice       Invoice?
  customer      Customer?    @relation(fields: [customerId], references: [id])
}

model PosBillItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  billId       String   @db.ObjectId
  productId    String   @db.ObjectId
  productName  String
  sku          String
  quantity     Int
  unitPrice    Int
  lineTax      Int
  lineTotal    Int
  createdAt    DateTime @default(now())
  bill         PosBill  @relation(fields: [billId], references: [id])
  product      Product  @relation(fields: [productId], references: [id])
}

model Invoice {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber Int
  billId        String        @unique @db.ObjectId
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  status        InvoiceStatus @default(PENDING)
  totalAmount   Int
  paidAmount    Int           @default(0)
  balanceAmount Int
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bill          PosBill       @relation(fields: [billId], references: [id])
  payments      Payment[]
}

model Payment {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  invoiceId     String        @db.ObjectId
  amount        Int
  method        PaymentMethod
  transactionRef String?
  note          String?
  createdAt     DateTime      @default(now())
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
}

model WarehouseTransfer {
  id             String                  @id @default(auto()) @map("_id") @db.ObjectId
  transferNumber Int
  fromWarehouseId String                 @db.ObjectId
  toWarehouseId  String                  @db.ObjectId
  status         TransferStatus          @default(DRAFT)
  note           String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  fromWarehouse  Warehouse               @relation("WarehouseTransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse    Warehouse               @relation("WarehouseTransferTo", fields: [toWarehouseId], references: [id])
  items          WarehouseTransferItem[]
}

model WarehouseTransferItem {
  id         String            @id @default(auto()) @map("_id") @db.ObjectId
  transferId String            @db.ObjectId
  productId  String            @db.ObjectId
  quantity   Int
  unitCost   Int               @default(0)
  transfer   WarehouseTransfer @relation(fields: [transferId], references: [id])
  product    Product           @relation(fields: [productId], references: [id])
}

model Account {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  code        String        @unique
  name        String
  type        AccountType
  description String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  journalLines JournalLine[]
}

model JournalEntry {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  entryNumber Int
  entryDate   DateTime      @default(now())
  reference   String?
  memo        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lines       JournalLine[]
}

model JournalLine {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  journalEntryId String       @db.ObjectId
  accountId      String       @db.ObjectId
  debitAmount    Int          @default(0)
  creditAmount   Int          @default(0)
  note           String?
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])
  account        Account      @relation(fields: [accountId], references: [id])
}

model Employee {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  employeeCode String         @unique
  name         String
  email        String?
  phone        String?
  role         String
  department   String?
  status       EmployeeStatus @default(ACTIVE)
  joinedAt     DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model AutomationWorkflow {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  module      String
  triggerType AutomationTriggerType
  isActive    Boolean             @default(true)
  configJson  String?
  lastRunAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  runs        AutomationRun[]
}

model AutomationRun {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  workflowId  String              @db.ObjectId
  status      AutomationRunStatus @default(PENDING)
  message     String?
  startedAt   DateTime            @default(now())
  finishedAt  DateTime?
  workflow    AutomationWorkflow  @relation(fields: [workflowId], references: [id])
}

model Counter {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}
